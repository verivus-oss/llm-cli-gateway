[Unit]
Description=Daily llm-cli-gateway host auto-upgrade check (latest npm release)
Documentation=file:///srv/repos/internal/verivusai-labs/rvwr/llm-cli-gateway/scripts/host-upgrade.sh

[Timer]
# Daily cadence debounces npm patch churn: at most one apply per day even when
# several patches shipped that day.
OnCalendar=daily
RandomizedDelaySec=30m
# Catch up after the machine was off.
Persistent=true

[Install]
WantedBy=timers.target