{
  "name": "llm-cli-gateway",
  "version": "1.0.0",
  "description": "MCP server providing unified access to Claude Code, Codex, and Gemini CLIs with session management, retry logic, and async job orchestration.",
  "license": "Apache-2.0",
  "author": {
    "name": "VerivusAI Labs",
    "url": "https://github.com/verivusai-labs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/verivusai-labs/llm-cli-gateway.git"
  },
  "homepage": "https://github.com/verivusai-labs/llm-cli-gateway#readme",
  "bugs": {
    "url": "https://github.com/verivusai-labs/llm-cli-gateway/issues"
  },
  "keywords": [
    "mcp",
    "llm",
    "claude",
    "codex",
    "gemini",
    "orchestration",
    "model-context-protocol",
    "ai",
    "cli-gateway"
  ],
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "llm-cli-gateway": "./dist/index.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "!dist/__tests__/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:all": "tsc",
    "prepublishOnly": "npm run build && npm test",
    "start": "node dist/index.js",
    "migrate": "node dist/migrate.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run src/__tests__/executor.test.ts",
    "test:session": "vitest run src/__tests__/session-manager.test.ts",
    "test:session-pg": "bash ./scripts/test-pg.sh src/__tests__/session-manager-pg.test.ts",
    "test:integration": "vitest run src/__tests__/integration.test.ts",
    "test:pg": "bash ./scripts/test-pg.sh",
    "test:all": "npm run test && npm run test:pg",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "check": "npm run build && npm run lint && npm test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "ioredis": "^5.4.1",
    "pg": "^8.12.0",
    "toml": "^3.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.30",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
